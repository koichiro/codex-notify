# Trusted credentials and destination profiles now belong in
# $XDG_CONFIG_HOME/codex-notify/config.yml or ~/.config/codex-notify/config.yml.
# See README.md for the YAML schema and manual migration instructions.
#
# These legacy entries remain supported temporarily when this sample is copied
# to the codex-notify project root. Keep the file mode at 0600.
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_CHANNEL=C0123456789
# SLACK_BOT_TOKEN__PROJECT_A=xoxb-project-a-token
# SLACK_CHANNEL__PROJECT_A=C1111111111
# CODEX_NOTIFY_ENV_POLICY=restricted

# Repository .env files should contain only routing and presentation settings.
# CODEX_NOTIFY_DESTINATION=PROJECT_A
# Optional durable delivery spool. Keep this directory private to the user.
# CODEX_NOTIFY_OUTBOX_DIR=/home/codex-notify/state/outbox

CODEX_NOTIFY_MODE=normal
