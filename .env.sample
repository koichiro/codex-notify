# Copy to .env, fill in your values, then run: chmod 600 .env
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=C0123456789

# Trusted named destination profiles for Hook mode.
# SLACK_BOT_TOKEN__PROJECT_A=xoxb-project-a-token
# SLACK_CHANNEL__PROJECT_A=C1111111111
# A profile may omit its token to reuse SLACK_BOT_TOKEN.

# Set this in the codex-notify environment to prevent automatically discovered
# repository .env files from supplying Slack credentials or raw channel IDs.
# CODEX_NOTIFY_ENV_POLICY=restricted
# Optional durable delivery spool. Keep this directory private to the user.
# CODEX_NOTIFY_OUTBOX_DIR=/home/codex-notify/state/outbox

CODEX_NOTIFY_MODE=normal
